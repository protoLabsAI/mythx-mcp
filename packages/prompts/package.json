{
  "name": "@mythxengine/prompts",
  "version": "0.1.0",
  "description": "Runtime GM skills for the MythxEngine MCP server (public skills-only subset)",
  "type": "module",
  "license": "MIT",
  "private": true,
  "exports": {
    "./skills": {
      "types": "./dist/skills.d.ts",
      "import": "./dist/skills.js",
      "default": "./dist/skills.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist",
    "src/skills"
  ]
}
