{
  "name": "mythx-mcp",
  "private": true,
  "type": "module",
  "description": "MythxEngine MCP server monorepo — public downstream mirror of the private MythxEngine repo",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,mts,js,mjs,cjs,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,mts,js,mjs,cjs,json,md}\" --ignore-path .prettierignore",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.1",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.54.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.13"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "^22"
    }
  }
}
